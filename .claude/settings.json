{
  "permissions": {
    "allow": [
      "Read(**)",
      "Grep(**)",
      "Glob(**)",
      "Bash(npm run build)",
      "Bash(npm ci)",
      "Bash(npm install)",
      "Bash(cargo check*)",
      "Bash(cargo test*)",
      "Bash(cargo fmt*)",
      "Bash(cargo clippy*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(*--no-verify*)",
      "Bash(rm -rf*)",
      "Bash(git reset --hard*)",
      "Edit(.env*)",
      "Read(.env*)"
    ]
  }
}
